# replicant.env - Template
# Copy this file to each replicant branch and fill in the values.
# This file is sourced by .github/hooks/session-start.sh and session-end.sh
# when running under copilot-bridge. Other tools (Claude Code, Codex, etc.)
# read identity directly from the REPLICANT IDENTITY block in AGENTS.md.

AGENT_NAME="<name>"
AGENT_WORKSPACE="/home/raykao/.copilot-bridge/workspaces/<name>"
BEADS_DIR="/home/raykao/.copilot-bridge/workspaces/<name>/.beads"
BEADS_ACTOR="<name>"
